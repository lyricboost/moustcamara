/*
Theme Name: Moust Camara - Plain
Author: Moust Camara
Description: Interim one-page theme for moustcamara.com
Version: 0.2
*/

:root {
  /* Brand Colors */
  --color-light-gray: #f5f5f5;
  --color-medium-gray: #e0e0e0;
  --color-dark-gray: #4a4a4a;
  --color-black: #1a1a1a;
  --color-white: #ffffff;
  --color-text-light: #ffffff;
  --color-text-dark: #1a1a1a;
  --color-text-gray: #666;
  
  /* Spacing */
  --spacing-xs: 8px;
  --spacing-sm: 16px;
  --spacing-md: 24px;
  --spacing-lg: 40px;
  --spacing-xl: 60px;
  --spacing-2xl: 80px;
  
  /* Container */
  --container-max-width: 1200px;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Poppins', system-ui, -apple-system, sans-serif;
  background: #ffffff;
  color: var(--color-text-dark);
  overflow-x: hidden;
}

/* ============================================
   HEADER STYLES
   ============================================ */

.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: #ffffff;
  border-bottom: 1px solid #e0e0e0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  transition: border-color 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
}

/* Transparent header state for pages using Home Page (Full Width) template when at top */
.page-template-page-home .site-header.header-transparent {
  background: transparent;
  border-bottom: none !important;
  box-shadow: none;
}

/* Ensure header text is dark for visibility on transparent header */
.page-template-page-home .site-header.header-transparent .logo-text,
.page-template-page-home .site-header.header-transparent .header-menu li a {
  color: #1a1a1a;
}

.page-template-page-home .site-header.header-transparent .hamburger-line {
  background: #1a1a1a;
}

/* Add padding to body to account for fixed header on pages NOT using Home Page (Full Width) template */
body:not(.page-template-page-home) .site-main {
  padding-top: 80px;
}

.header-container {
  margin: 0;
  padding: 1rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-logo a {
  text-decoration: none;
  color: #1a1a1a;
}

.logo-text {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.5px;
}

/* Desktop Navigation */
.desktop-nav {
  display: none;
}

.header-menu {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  gap: 2rem;
}

.header-menu li a {
  text-decoration: none;
  color: #4a4a4a;
  font-weight: 500;
  font-size: 0.95rem;
  transition: color 0.2s ease;
}

.header-menu li a:hover {
  color: #1a1a1a;
}

.header-menu li.current-menu-item a,
.header-menu li.current_page_item a {
  color: #1a1a1a;
}

/* Mobile Menu Toggle */
.mobile-menu-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 1001;
}

.hamburger {
  width: 24px;
  height: 18px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hamburger-line {
  width: 100%;
  height: 2px;
  background: #1a1a1a;
  transition: all 0.3s ease;
}

.menu-open .hamburger-line:nth-child(1) {
  transform: rotate(45deg) translate(6px, 6px);
}

.menu-open .hamburger-line:nth-child(2) {
  opacity: 0;
}

.menu-open .hamburger-line:nth-child(3) {
  transform: rotate(-45deg) translate(6px, -6px);
}

/* Mobile Drawer */
.mobile-drawer {
  position: fixed;
  top: 0;
  right: -100%;
  width: 300px;
  height: 100vh;
  background: #ffffff;
  box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
  transition: right 0.3s ease;
  z-index: 1002;
  overflow-y: auto;
}

.mobile-drawer.active {
  right: 0;
}

.mobile-drawer-inner {
  padding: 5rem 2rem 2rem;
}

.mobile-menu {
  list-style: none;
  margin: 0;
  padding: 0;
}

.mobile-menu li {
  margin-bottom: 0.5rem;
}

.mobile-menu li a {
  display: block;
  padding: 1rem;
  text-decoration: none;
  color: #4a4a4a;
  font-size: 1.1rem;
  font-weight: 500;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.mobile-menu li a:hover {
  background: #f5f5f5;
  color: #1a1a1a;
}

.mobile-menu li.current-menu-item a,
.mobile-menu li.current_page_item a {
  background: #f5f5f5;
  color: #1a1a1a;
}

/* Mobile Overlay */
.mobile-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1001;
}

.mobile-overlay.active {
  opacity: 1;
  visibility: visible;
}

/* Prevent scroll when menu is open */
body.menu-open {
  overflow: hidden;
}

/* Desktop Navigation - Show on larger screens */
@media (min-width: 768px) {
  .desktop-nav {
    display: block;
  }

  .mobile-menu-toggle {
    display: none;
  }

  .mobile-drawer,
  .mobile-overlay {
    display: none;
  }
}

/* ============================================
   FOOTER STYLES
   ============================================ */

.site-footer {
  background: #1a1a1a;
  color: #ffffff;
  padding: 4rem 2rem 2rem;
  margin-top: 4rem;
}

.footer-container {
  max-width: 1200px;
  margin: 0 auto;
}

.footer-content {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand {
  max-width: 400px;
}

.footer-logo {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  color: #ffffff;
}

.footer-tagline {
  color: #b0b0b0;
  line-height: 1.6;
  margin: 0;
}

.footer-links {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

.footer-column h4 {
  font-size: 0.9rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin: 0 0 1rem 0;
  color: #ffffff;
}

.footer-menu,
.footer-social {
  list-style: none;
  margin: 0;
  padding: 0;
}

.footer-menu li,
.footer-social li {
  margin-bottom: 0.5rem;
}

.footer-menu li a,
.footer-social li a {
  color: #b0b0b0;
  text-decoration: none;
  transition: color 0.2s ease;
  font-size: 0.95rem;
}

.footer-menu li a:hover,
.footer-social li a:hover {
  color: #ffffff;
}

.footer-column p {
  color: #b0b0b0;
  margin: 0;
}

.footer-bottom {
  padding-top: 2rem;
  border-top: 1px solid #333333;
  text-align: center;
}

.footer-bottom p {
  margin: 0;
  color: #808080;
  font-size: 0.9rem;
}

/* Footer Responsive */
@media (min-width: 640px) {
  .footer-links {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 768px) {
  .footer-content {
    grid-template-columns: 1.5fr 2fr;
  }

  .footer-links {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1024px) {
  .footer-content {
    grid-template-columns: 2fr 3fr;
  }
}

/* ============================================
   MAIN CONTENT
   ============================================ */

.site-main {
  min-height: 50vh;
}

/* Container Utilities */
.container {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 0 var(--spacing-lg);
}

/* Background Color System */
.bg-none {
  background: transparent;
}

.bg-light-gray {
  background: var(--color-light-gray);
}

.bg-medium-gray {
  background: var(--color-medium-gray);
}

.bg-dark-gray {
  background: var(--color-dark-gray);
}

.bg-black {
  background: var(--color-black);
}

.bg-white {
  background: var(--color-white);
}

/* Text Color Utilities */
.text-light {
  color: var(--color-text-light) !important;
}

.text-light .hero-founder,
.text-light .hero-location {
  color: rgba(255, 255, 255, 0.85);
}

.text-light .hero-link,
.text-light .hero-founder a {
  color: var(--color-text-light);
  border-color: var(--color-text-light);
}

.text-light .split-text,
.text-light .split-text-secondary,
.text-light .grid-item-description,
.text-light .final-cta-text {
  color: rgba(255, 255, 255, 0.9);
}

.text-light .split-heading,
.text-light .grid-items-heading,
.text-light .grid-item-title,
.text-light .final-cta-heading {
  color: var(--color-text-light);
}

/* Page Templates */
.page-home,
.page-fullwidth {
  width: 100%;
}

.page-default {
  padding: var(--spacing-2xl) 0;
}

.page-default .entry-header {
  margin-bottom: var(--spacing-xl);
  text-align: center;
}

.page-default .entry-title {
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 700;
  line-height: 1.2;
  color: var(--color-text-dark);
}

.hero-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  position: relative;
}

/* On pages with Home Page (Full Width) template, hero extends to top of viewport */
.page-template-page-home .hero-section {
  padding-top: 120px;
}

.hero-section-inner {
  max-width: 1200px;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 60px;
  position: relative;
}

.hero-content {
  flex: 1;
  max-width: 550px;
  min-width: 0;
}

.hero-location {
  font-size: 14px;
  font-weight: 500;
  margin-top: 40px;
  margin-bottom: 24px;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8px;
}

.hero-location .hero-icon {
  width: 16px;
  height: 16px;
  stroke-width: 2;
}

.hero-name {
  font-size: clamp(56px, 8vw, 96px);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 32px;
}

.hero-about {
  font-size: clamp(15px, 1.8vw, 17px);
  font-weight: 400;
  line-height: 1.7;
  margin-bottom: 16px;
  max-width: 500px;
}

.hero-founder {
  font-size: 14px;
  font-weight: 400;
  color: #666;
  margin-bottom: 16px;
}

.hero-founder a {
  color: #1a1a1a;
  text-decoration: underline;
  font-weight: 500;
  transition: opacity 0.2s;
}

.hero-founder a:hover {
  opacity: 0.6;
}

.hero-links {
  display: flex;
  gap: 20px;
}

.hero-link {
  font-size: 15px;
  font-weight: 500;
  color: #1a1a1a;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid #1a1a1a;
  padding-bottom: 3px;
  transition: all 0.2s;
}

.hero-link .hero-icon {
  width: 16px;
  height: 16px;
  stroke-width: 2;
}

.hero-link:hover {
  opacity: 0.6;
  transform: translateY(-1px);
}

.hero-image {
  flex: 1;
  position: relative;
  align-self: stretch;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
}

.hero-image-circle {
  width: clamp(400px, 45vw, 550px);
  height: clamp(400px, 45vw, 550px);
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
}

.hero-image-circle::after {
  content: '';
  position: absolute;
  bottom: -50px;
  right: -50px;
  width: 200px;
  height: 200px;
  background: linear-gradient(135deg, rgba(255, 200, 150, 0.4), rgba(200, 150, 255, 0.4));
  border-radius: 50%;
  filter: blur(60px);
  z-index: -1;
}

.hero-image-circle img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* Mobile adjustments */
@media (max-width: 968px) {
  .hero-section-inner {
    flex-direction: column;
    gap: 40px;
    text-align: center;
  }
  
  .hero-content {
    max-width: 100%;
  }
  
  .hero-location {
    justify-content: center;
  }
  
  .hero-about {
    max-width: 100%;
  }
  
  .hero-links {
    justify-content: center;
  }
  
  .hero-image {
    justify-content: center;
  }
  
  .hero-image-circle {
    width: clamp(280px, 70vw, 400px);
    height: clamp(280px, 70vw, 400px);
  }
}

@media (max-width: 640px) {
  .hero-section {
    padding: 40px 24px;
  }
  
  .hero-name {
    font-size: clamp(36px, 10vw, 48px);
  }
  
  .hero-image-circle {
    width: clamp(240px, 80vw, 320px);
    height: clamp(240px, 80vw, 320px);
  }
}
/* ========================================
   LEAD-IN TEXT BLOCK
   ======================================== */
.lead-in-section {
  padding: var(--spacing-2xl) var(--spacing-lg);
  text-align: center;
}

.lead-in-inner {
  max-width: 1000px;
  margin: 0 auto;
}

.lead-in-text {
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 500;
  line-height: 1.5;
  color: var(--color-text-dark);
}

.lead-in-text em {
  font-style: italic;
  font-weight: 700;
}

@media (max-width: 768px) {
  .lead-in-section {
    padding: var(--spacing-xl) var(--spacing-md);
  }
}

/* ========================================
   SPLIT LAYOUT BLOCK
   ======================================== */
.split-section {
  padding: var(--spacing-2xl) var(--spacing-lg);
}

.split-inner {
  max-width: var(--container-max-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-xl);
  align-items: center;
}

.split-image-wrapper {
  border-radius: 50%;
  overflow: hidden;
  width: 100%;
  max-width: 500px;
  aspect-ratio: 1;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
}

.split-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.split-left .split-image {
  order: 1;
  display: flex;
  justify-content: flex-start;
}

.split-left .split-content {
  order: 2;
}

.split-right .split-image {
  order: 2;
  display: flex;
  justify-content: flex-end;
}

.split-right .split-content {
  order: 1;
}

.split-heading {
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 600;
  line-height: 1.3;
  margin-bottom: var(--spacing-md);
  color: inherit;
}

.split-text {
  font-size: clamp(16px, 1.5vw, 18px);
  line-height: 1.7;
  margin-bottom: var(--spacing-sm);
  color: var(--color-text-gray);
}

.split-text-secondary {
  font-size: clamp(15px, 1.4vw, 17px);
  line-height: 1.7;
  color: var(--color-text-gray);
}

.text-light .split-text,
.text-light .split-text-secondary {
  color: rgba(245, 245, 245, 0.9);
}

@media (max-width: 968px) {
  .split-inner {
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
    text-align: center;
  }
  
  .split-left .split-image,
  .split-right .split-image {
    order: 1;
    justify-content: center;
  }
  
  .split-left .split-content,
  .split-right .split-content {
    order: 2;
  }
  
  .split-image-wrapper {
    max-width: 400px;
    margin: 0 auto;
  }
}

@media (max-width: 640px) {
  .split-section {
    padding: var(--spacing-xl) var(--spacing-md);
  }
  
  .split-image-wrapper {
    max-width: 300px;
  }
}

/* ========================================
   GRID ITEMS BLOCK
   ======================================== */
.grid-items-section {
  padding: var(--spacing-2xl) var(--spacing-lg);
}

.grid-items-inner {
  max-width: var(--container-max-width);
  margin: 0 auto;
}

.grid-items-heading {
  font-size: clamp(32px, 4vw, 48px);
  font-weight: 600;
  text-align: center;
  margin-bottom: var(--spacing-xl);
  color: inherit;
}

.grid-items-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-lg);
}

.grid-item {
  text-align: center;
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.grid-item-title {
  font-size: clamp(20px, 2vw, 24px);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: inherit;
}

.grid-item-description {
  font-size: clamp(14px, 1.3vw, 16px);
  line-height: 1.7;
  margin-bottom: var(--spacing-lg);
  color: var(--color-text-gray);
  flex-grow: 1;
}

.text-light .grid-item-description {
  color: rgba(245, 245, 245, 0.85);
}

.grid-item-button {
  display: inline-block;
  padding: 14px 32px;
  background: var(--color-light-gray);
  color: var(--color-text-dark);
  text-decoration: none;
  border-radius: 50px;
  font-weight: 500;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.grid-item-button:hover {
  background: var(--color-medium-gray);
  color: var(--color-text-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
}

.text-light .grid-item-button {
  background: var(--color-white);
  color: var(--color-text-dark);
}

.text-light .grid-item-button:hover {
  background: var(--color-light-gray);
  color: var(--color-text-dark);
}

@media (max-width: 968px) {
  .grid-items-grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }
}

@media (max-width: 640px) {
  .grid-items-section {
    padding: var(--spacing-xl) var(--spacing-md);
  }
}

/* ========================================
   FINAL CTA BLOCK
   ======================================== */
.final-cta-section {
  padding: var(--spacing-2xl) var(--spacing-lg);
  text-align: center;
}

.final-cta-inner {
  max-width: 800px;
  margin: 0 auto;
}

.final-cta-heading {
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: inherit;
}

.final-cta-text {
  font-size: clamp(16px, 1.6vw, 20px);
  line-height: 1.6;
  margin-bottom: var(--spacing-lg);
  color: var(--color-text-gray);
}

.text-light .final-cta-text {
  color: rgba(245, 245, 245, 0.9);
}

.final-cta-button {
  display: inline-block;
  padding: 16px 48px;
  background: var(--color-light-gray);
  color: var(--color-text-dark);
  text-decoration: none;
  border-radius: 50px;
  font-weight: 600;
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  transition: all 0.3s ease;
}

.final-cta-button:hover {
  background: var(--color-medium-gray);
  color: var(--color-text-dark);
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.text-light .final-cta-button {
  background: var(--color-white);
  color: var(--color-text-dark);
}

.text-light .final-cta-button:hover {
  background: var(--color-light-gray);
  color: var(--color-text-dark);
}

@media (max-width: 640px) {
  .final-cta-section {
    padding: var(--spacing-xl) var(--spacing-md);
  }
  
  .final-cta-button {
    padding: 14px 36px;
    font-size: 14px;
  }
}

/* ========================================
   WORDPRESS ALIGNMENT CLASSES
   ======================================== */
.alignwide {
  max-width: 1400px;
  margin-left: auto;
  margin-right: auto;
}

.alignfull {
  width: 100vw;
  max-width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
}